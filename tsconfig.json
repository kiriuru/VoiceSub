{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "src-worker/**/*.ts", "src-worker/**/*.svelte", "src-worker/env.d.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src-worker/**/*.test.ts",
    "vitest.lib.config.ts",
    "vitest.lib.setup.ts",
    "vitest.worker.config.ts",
    "vitest.renderer.config.ts",
    "tests/renderer/**"
  ]
}
