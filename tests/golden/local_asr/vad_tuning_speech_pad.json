{
  "source_test": "vad tuning speech pad extends finalize",
  "config": {
    "enabled": true,
    "speech_threshold": 0.01,
    "min_speech_ms": 100,
    "min_silence_ms": 100,
    "silence_hold_ms": 50,
    "speech_pad_ms": 200,
    "max_segment_ms": 30000
  },
  "sample_rate": 16000,
  "frame_samples": 320,
  "speech_level": 0.02,
  "steps": [
    { "kind": "speech", "repeat": 8, "expect_finalize": false, "expect_state": "speech" },
    { "kind": "silence", "repeat": 8, "expect_finalize": false, "expect_state": "speech_pad" },
    { "kind": "silence", "repeat": 8, "expect_finalize": true, "expect_state": "silence" }
  ]
}
