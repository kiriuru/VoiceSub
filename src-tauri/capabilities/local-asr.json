{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "local-asr",
  "description": "Local ASR module webview — token + allowlisted URLs only",
  "windows": ["local-asr"],
  "remote": {
    "urls": ["http://localhost:*", "http://127.0.0.1:*"]
  },
  "permissions": [
    "allow-voicesub-local-asr-ipc",
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus"
  ]
}
